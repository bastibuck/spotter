# Drizzle
DATABASE_URL="postgresql://postgres:password@localhost:5432/spotter"

# Next Auth
# You can generate a new secret on the command line with:
# openssl rand -base64 32
# https://next-auth.js.org/configuration/options#secret
NEXTAUTH_SECRET="SOME_SECRET"
NEXTAUTH_URL="http://localhost:3000"

GITHUB_CLIENT_ID=CLIENT_ID
GITHUB_CLIENT_SECRET=CLIENT_SECRET

ADMIN_GITHUB_IDS=1234567890,9876543210

CRON_SECRET=SOMETOKEN

RESEND_API_KEY=SOMEAPIKEY
FROM_EMAIL="Name <some@example.com>"
SUGGESTION_DIGEST_TO_EMAIL=admin@example.com
SKIP_EMAIL_DELIVERY=true
